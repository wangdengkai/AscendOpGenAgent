      "l2_read_rate": 100,
      "l2_write_rate": 100,
      "l1_to_l0_a_rate": 256,
      "l1_to_l0_b_rate": 256,
      "l1_to_ub_rate": 128,
      "l0_c_to_ub_rate": 128,
      "ub_to_l2_rate": 128,
      "ub_to_ddr_rate": 128,
      "ub_to_l1_rate": 128,
      "ddr_rate": "see variants (varies by SKU)"
    },

    "memory_rates_vectorcore": {
      "_comment": "VectorCore 搬运速率 (Bytes/cycle), ddr_rate 为 CubeCore 的约一半",
      "l2_rate": 100,
      "l2_read_rate": 100,
      "l2_write_rate": 100,
      "ub_to_l2_rate": 42,
      "ub_to_ddr_rate": 40,
      "ddr_rate": "see variants (约为 CubeCore 的一半)"
    },

    "alignment": {
      "base_alignment_bytes": 32,
      "block_size_elements": {
        "fp16": 16,
        "bf16": 16,
        "fp32": 8,
        "int8": 32,
        "int16": 16,
        "int32": 8
      }
    },

    "features": {
      "support_bf16": true,
      "support_inf_nan": true,
      "support_fixpipe": true,
      "sparsity": false,
      "note": "910_95xx 系列 sparsity=0"
    }
  },

