      "note": "支持 fuse 和 split 模式, vector_core_cnt = cube_core_cnt (1:1)"
    },

    "vector_unit": {
      "vec_calc_size_bytes": 128,
      "fp16_elements_per_instruction": 64,
      "fp32_elements_per_instruction": 32
    },

    "cube_unit": {
      "cube_m_size": 16,
      "cube_n_size": 16,
      "cube_k_size": 16
    },

    "memory": {
      "ub": {
        "size_bytes": 253952,
        "size_readable": "248KB",
        "ubblock_size": 32,
        "ubbank_size": 4096,
        "ubbank_num": 16,
        "ubbank_group_num": 8,
        "ubburst_in_one_block": 32
      },
      "l0a": { "size_bytes": 65536, "size_readable": "64KB" },
      "l0b": { "size_bytes": 65536, "size_readable": "64KB" },
      "l0c": { "size_bytes": 262144, "size_readable": "256KB" },
      "l1": { "size_bytes": 524288, "size_readable": "512KB" }
    },

    "memory_rates": {
      "_comment": "单位: Bytes/cycle, CubeCore 和 VectorCore 搬运速率相同",
      "ddr_rate": 112,
      "ddr_read_rate": 112,
      "ddr_write_rate": 112,
      "l2_rate": 128,
      "l2_read_rate": 128,
      "l2_write_rate": 128,
      "l1_to_l0_a_rate": 256,
      "l1_to_l0_b_rate": 256,
      "l1_to_ub_rate": 128,
      "l0_c_to_ub_rate": 128,
      "ub_to_l2_rate": 128,
      "ub_to_ddr_rate": 128,
      "ub_to_l1_rate": 128
