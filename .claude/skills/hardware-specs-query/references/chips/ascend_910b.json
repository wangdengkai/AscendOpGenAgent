{
  "chip_series": "Ascend 910B",
  "description": "Ascend 910B 系列芯片硬件规格参数，数据来源: platform_config/*.ini",
  "data_source": "platform_config/Ascend910B*.ini",

  "shared": {
    "_comment": "以下参数在 910B 全系列（Gen2: B1/B2/B2C/B3/B4/B4-1）中相同，910B(Gen1) 单独标注差异",

    "ai_core_architecture": {
      "core_type": "AI Core",
      "cube_vector_combine": "split",
      "core_type_list": ["CubeCore", "VectorCore"],
      "ai_cpu_cnt": 6,
      "note": "Gen2 将 Cube 和 Vector 拆分为独立核; Gen1(910B) 为统一 AI Core"
    },

    "vector_unit": {
      "vec_calc_size_bytes": 128,
      "fp16_elements_per_instruction": 64,
      "fp32_elements_per_instruction": 32,
      "note": "vec_calc_size=128 表示每次向量指令处理 128 Bytes"
    },

    "cube_unit": {
      "cube_m_size": 16,
      "cube_n_size": 16,
      "cube_k_size": 16,
      "note": "16×16×16 矩阵乘单元"
    },

    "memory": {
      "ub": {
        "size_bytes_gen2": 196608,
        "size_readable_gen2": "192KB",
        "size_bytes_gen1_910b": 262144,
        "size_readable_gen1_910b": "256KB",
        "ubblock_size": 32,
        "ubbank_size": 4096,
        "ubbank_num": 64,
        "ubbank_group_num": 16,
        "ubburst_in_one_block": 32,
        "note": "Gen2(B1~B4) UB=192KB; Gen1(910B) UB=256KB"
      },
      "l0a": { "size_bytes": 65536, "size_readable": "64KB" },
      "l0b": { "size_bytes": 65536, "size_readable": "64KB" },
      "l0c": {
        "size_bytes_gen2": 131072,
        "size_readable_gen2": "128KB",
        "size_bytes_gen1_910b": 262144,
        "size_readable_gen1_910b": "256KB"
      },
      "l1": {
        "size_bytes_gen2": 524288,
        "size_readable_gen2": "512KB",
        "size_bytes_gen1_910b": 1048576,
        "size_readable_gen1_910b": "1MB"
      }
    },

    "memory_rates": {
      "_comment": "单位: Bytes/cycle, 全系列相同",
      "ddr_rate": 32,
      "ddr_read_rate": 32,
      "ddr_write_rate": 32,
      "l2_rate": 110,
      "l2_read_rate": 110,
      "l2_write_rate": 86,
      "l1_to_l0_a_rate": 512,
      "l1_to_l0_b_rate": 256,
      "l1_to_ub_rate": 128,
      "l0_c_to_ub_rate": 256,
      "ub_to_l2_rate": 64,
      "ub_to_ddr_rate": 64,
      "ub_to_l1_rate": 128
    },

    "alignment": {
      "base_alignment_bytes": 32,
      "block_size_elements": {
        "fp16": 16,
        "bf16": 16,
        "fp32": 8,
        "int8": 32,
        "int16": 16,
        "int32": 8
      }
    },

    "pipeline": {
      "stages": ["MTE2 (GM→UB)", "Vector/Cube (计算)", "MTE3 (UB→GM)"],
      "double_buffer_overlap": true,
      "pipe_barrier_types": ["PIPE_ALL", "PIPE_V", "PIPE_MTE2", "PIPE_MTE3", "PIPE_S"],
      "sync_mechanisms": ["EnQue/DeQue", "SetFlag/WaitFlag", "PipeBarrier"]
    },

    "features_gen2": {
      "support_bf16": true,
      "support_inf_nan": true,
      "support_fixpipe": true,
      "sparsity": true,
      "ffts_mode": "ffts-plus",
      "hardware_sync_betweencore": true
    },

    "dtype_mkn": {
      "default": [16, 16, 16],
      "int8": [16, 32, 16],
      "uint8": [16, 32, 16],
      "int4": [16, 64, 16],
      "int2": [16, 128, 16]
    },

    "unzip": {
      "engines": 4,
      "max_ratios": 64,
      "channels": 2
    }
  },

