    "alignment": {
      "base_alignment_bytes": 32,
      "block_size_elements": {
        "fp16": 16,
        "fp32": 8,
        "int8": 32,
        "int16": 16,
        "int32": 8
      }
    },

    "features": {
      "support_fixpipe": true,
      "sparsity": false
    }
  },

  "variants": {
    "910_5591": {
      "aic_version": "AIC-C-310",
      "npu_arch": null,
      "ai_core_cnt": 24,
      "cube_core_cnt": 24,
      "vector_core_cnt": 24,
      "ai_cpu_cnt": 7,
      "cube_freq_mhz": 1500,
      "l2_size_bytes": 50331648,
      "l2_size_readable": "48MB",
      "gm_size_bytes": 34359738368,
      "gm_size_readable": "32GB",
      "note": "vector_core_cnt=cube_core_cnt=24, 1:1 比例"
    }
  },

  "derived_params": {
    "examples": {
      "5591_gm_to_ub_per_core_gbps": "ddr_rate(112) x freq(1500) / 1000 = 168.0 GB/s per core",
      "5591_cube_fp16_tflops_per_core": "16x16x16 x 2 x 1500 / 1e6 = 12.288 TFLOPS",
      "5591_cube_fp16_aggregate_tflops": "12.288 x 24 = 294.912 TFLOPS"
    }
  },

  "lookup_rule": "检测芯片型号 -> 读 shared 获取通用参数 -> 读 variants[型号] 获取核数/频率/容量"
