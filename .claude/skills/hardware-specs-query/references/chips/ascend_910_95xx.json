    "ai_core_architecture": {
      "core_type": "AI Core",
      "cube_vector_combine": "fuse,split",
      "core_type_list": ["CubeCore", "VectorCore"],
      "note": "支持 fuse 和 split 两种模式; vector_core_cnt = 2 x cube_core_cnt"
