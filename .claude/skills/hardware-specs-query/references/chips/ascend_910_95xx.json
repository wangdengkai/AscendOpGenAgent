  "derived_params": {
    "calculation_notes": {
      "bandwidth_per_core_gbps": "ddr_rate_cube (Bytes/cycle) x freq (MHz) / 1000 = GB/s",
      "cube_fp16_tflops_per_core": "16x16x16 x 2 x freq / 1e6 = TFLOPS/core",
      "vector_fp16_tflops_per_core": "128B / 2B x freq x 2(FMA) / 1e6 = TFLOPS/core"
    },
    "examples": {
      "9591_gm_to_ub_per_core_gbps": "ddr_rate_cube(80) x freq(1800) / 1000 = 144.0 GB/s per core",
      "9591_cube_fp16_tflops_per_core": "16x16x16 x 2 x 1800 / 1e6 = 14.746 TFLOPS",
      "9591_cube_fp16_aggregate_tflops": "14.746 x 36 = 530.841 TFLOPS",
      "950z_gm_to_ub_per_core_gbps": "ddr_rate_cube(4) x freq(1650) / 1000 = 6.6 GB/s per core",
      "950z_cube_fp16_aggregate_tflops": "16x16x16 x 2 x 1650 / 1e6 x 8 = 108.04 TFLOPS"
    }
  },

  "lookup_rule": "检测芯片型号 -> 匹配 tier -> 读 shared 获取通用参数 -> 读 variants[型号] 获取核数/频率/ddr_rate/容量 -> 注意区分 CubeCore 和 VectorCore 的 ddr_rate"
}
