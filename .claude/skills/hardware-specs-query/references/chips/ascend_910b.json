  "derived_params": {
    "_comment": "以下参数需要根据 variant 的 core_count 和 freq 计算",
    "calculation_notes": {
      "bandwidth_per_core_gbps": "memory_rate (Bytes/cycle) × cube_freq (MHz) × 1e6 / 1e9 = rate × freq / 1000 GB/s",
      "aggregate_bandwidth_gbps": "per_core_gbps × ai_core_cnt",
      "vector_fp16_tflops_per_core": "vec_calc_size / sizeof(fp16) × cube_freq × 1e6 × 2(FMA) / 1e12",
      "cube_fp16_tflops_per_core": "cube_m × cube_n × cube_k × 2 × cube_freq × 1e6 / 1e12"
    },
    "examples": {
      "910B3_gm_to_ub_per_core_gbps": "ddr_rate(32) × freq(1800) / 1000 = 57.6 GB/s per core",
      "910B3_gm_to_ub_aggregate_gbps": "57.6 × 20 cores = 1152 GB/s (理论峰值，实际受 HBM 限制)",
      "910B3_vector_fp16_tflops_per_core": "128B / 2B × 1800MHz × 2 / 1e6 = 0.2304 TFLOPS",
      "910B3_vector_fp16_aggregate_tflops": "0.2304 × 20 = 4.608 TFLOPS",
      "910B3_cube_fp16_tflops_per_core": "16×16×16 × 2 × 1800 / 1e6 = 14.746 TFLOPS",
      "910B3_cube_fp16_aggregate_tflops": "14.746 × 20 = 294.912 TFLOPS"
    }
  },

  "lookup_rule": "检测芯片型号 → 读 shared 获取通用参数 → 读 variants[型号] 获取核数/频率/容量 → 用 derived_params 公式计算带宽和算力"
